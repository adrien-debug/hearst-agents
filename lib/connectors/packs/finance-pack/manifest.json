{
  "id": "finance-pack",
  "name": "Finance Pack",
  "description": "Connecteurs financiers pour paiements, facturation, comptabilité et banque. Inclut Stripe, QuickBooks, Xero, Plaid, et Wise.",
  "version": "1.0.0",
  "category": "finance",
  "author": "Hearst AI",
  "license": "MIT",
  "homepage": "https://github.com/adrien-debug/hearst-agents/tree/main/lib/connectors/packs/finance-pack",
  "minHearstVersion": "1.0.0",
  "connectors": [
    {
      "id": "stripe",
      "name": "Stripe",
      "description": "Plateforme de paiements complète pour Internet. Paiements, facturation, abonnements, et plus.",
      "version": "1.0.0",
      "category": "finance",
      "auth": {
        "type": "oauth2",
        "scopes": [
          "read_write",
          "read_only"
        ],
        "additionalConfig": [
          "webhook_secret"
        ]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": true,
        "webhooks": true,
        "realtime": true
      },
      "icon": "💳",
      "docsUrl": "https://stripe.com/docs",
      "supportUrl": "https://support.stripe.com",
      "rateLimits": {
        "requestsPerSecond": 100
      },
      "healthCheck": {
        "endpoint": "/v1/charges?limit=1",
        "method": "GET",
        "expectedStatus": 200
      }
    },
    {
      "id": "quickbooks",
      "name": "QuickBooks Online",
      "description": "Logiciel de comptabilité pour PME. Facturation, suivi des dépenses, rapports financiers.",
      "version": "1.0.0",
      "category": "finance",
      "auth": {
        "type": "oauth2",
        "scopes": [
          "compta",
          "openid",
          "email",
          "profile"
        ]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": false,
        "webhooks": true,
        "realtime": false
      },
      "icon": "📊",
      "docsUrl": "https://developer.intuit.com/app/developer/qbo/docs",
      "dependencies": [],
      "rateLimits": {
        "requestsPerMinute": 500
      }
    },
    {
      "id": "xero",
      "name": "Xero",
      "description": "Logiciel de comptabilité cloud. Comptabilité, facturation, paie, et rapports.",
      "version": "1.0.0",
      "category": "finance",
      "auth": {
        "type": "oauth2",
        "scopes": [
          "accounting.transactions",
          "accounting.contacts",
          "accounting.reports.read"
        ]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": false,
        "webhooks": true,
        "realtime": false
      },
      "icon": "📈",
      "docsUrl": "https://developer.xero.com/documentation/",
      "conflicts": [
        "quickbooks"
      ],
      "rateLimits": {
        "requestsPerMinute": 1000
      }
    },
    {
      "id": "plaid",
      "name": "Plaid",
      "description": "Connexion bancaire sécurisée. Accès aux comptes, transactions, vérifications d'identité.",
      "version": "0.5.0",
      "category": "finance",
      "auth": {
        "type": "api_key",
        "additionalConfig": [
          "client_id",
          "secret",
          "environment"
        ]
      },
      "capabilities": {
        "read": true,
        "write": false,
        "delete": false,
        "webhooks": true,
        "realtime": false
      },
      "icon": "🏦",
      "docsUrl": "https://plaid.com/docs/",
      "rateLimits": {
        "requestsPerHour": 200
      }
    },
    {
      "id": "wise",
      "name": "Wise (TransferWise)",
      "description": "Transferts internationaux à faible coût. Virements, conversion de devises, comptes multi-devises.",
      "version": "0.5.0",
      "category": "finance",
      "auth": {
        "type": "api_key"
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": false,
        "webhooks": false,
        "realtime": true
      },
      "icon": "💱",
      "docsUrl": "https://docs.wise.com/",
      "rateLimits": {
        "requestsPerMinute": 60
      }
    }
  ]
}
