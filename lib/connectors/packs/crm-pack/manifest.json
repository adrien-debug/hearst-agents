{
  "id": "crm-pack",
  "name": "CRM Pack",
  "description": "Customer Relationship Management connectors including HubSpot and Salesforce",
  "version": "1.0.0",
  "category": "crm",
  "author": "Hearst OS",
  "license": "MIT",
  "connectors": [
    {
      "id": "hubspot",
      "name": "HubSpot",
      "description": "HubSpot CRM - Contacts, Companies, Deals, and Activities",
      "version": "1.0.0",
      "category": "crm",
      "auth": {
        "type": "oauth2",
        "scopes": ["crm.objects.contacts.read", "crm.objects.contacts.write", "crm.objects.companies.read", "crm.objects.deals.read"]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": false,
        "webhooks": false,
        "realtime": false
      },
      "icon": "/icons/hubspot.svg",
      "docsUrl": "https://developers.hubspot.com/docs/api/crm",
      "rateLimits": {
        "requestsPerMinute": 100
      }
    },
    {
      "id": "salesforce",
      "name": "Salesforce",
      "description": "Salesforce CRM - Leads, Accounts, Opportunities, and Contacts",
      "version": "1.0.0",
      "category": "crm",
      "auth": {
        "type": "oauth2",
        "scopes": ["api", "refresh_token"]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": false,
        "webhooks": true,
        "realtime": false
      },
      "icon": "/icons/salesforce.svg",
      "docsUrl": "https://developer.salesforce.com/docs",
      "rateLimits": {
        "requestsPerHour": 1000
      },
      "healthCheck": {
        "endpoint": "/services/data/v58.0/sobjects/Account",
        "method": "GET",
        "expectedStatus": 200
      }
    }
  ]
}
