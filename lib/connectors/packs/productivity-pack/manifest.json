{
  "id": "productivity-pack",
  "name": "Productivity Pack",
  "description": "Productivity and collaboration tools including Notion, Trello, and Asana",
  "version": "1.0.0",
  "category": "productivity",
  "author": "Hearst OS",
  "license": "MIT",
  "connectors": [
    {
      "id": "notion",
      "name": "Notion",
      "description": "Notion - Pages, Databases, Workspaces, and Collaboration",
      "version": "1.0.0",
      "category": "productivity",
      "auth": {
        "type": "oauth2",
        "scopes": ["read_content", "write_content", "read_user"]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": true,
        "webhooks": false,
        "realtime": false
      },
      "icon": "/icons/notion.svg",
      "docsUrl": "https://developers.notion.com",
      "rateLimits": {
        "requestsPerSecond": 3
      },
      "healthCheck": {
        "endpoint": "/v1/users/me",
        "method": "GET",
        "expectedStatus": 200
      }
    },
    {
      "id": "trello",
      "name": "Trello",
      "description": "Trello - Boards, Lists, Cards, and Team Collaboration",
      "version": "1.0.0",
      "category": "productivity",
      "auth": {
        "type": "oauth2",
        "scopes": ["read", "write"]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": true,
        "webhooks": true,
        "realtime": false
      },
      "icon": "/icons/trello.svg",
      "docsUrl": "https://developer.atlassian.com/cloud/trello",
      "rateLimits": {
        "requestsPerSecond": 10
      }
    },
    {
      "id": "asana",
      "name": "Asana",
      "description": "Asana - Projects, Tasks, Sections, and Workspaces",
      "version": "1.0.0",
      "category": "productivity",
      "auth": {
        "type": "oauth2",
        "scopes": ["default"]
      },
      "capabilities": {
        "read": true,
        "write": true,
        "delete": true,
        "webhooks": true,
        "realtime": false
      },
      "icon": "/icons/asana.svg",
      "docsUrl": "https://developers.asana.com",
      "rateLimits": {
        "requestsPerMinute": 150
      }
    }
  ]
}
