# ── HEARST OS — Environment Variables ──
# Reference template. Copy to .env.local and fill in real values.
# Vars without value here are required in code (will throw at boot or fail-soft).

# ── Local dev ──
# Auto-open URLs in Google Chrome (npm run dev, npm run launch). 0 to disable.
HEARST_OPEN_CHROME=1

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Personal access token, used only by scripts/migrate-* utilities. Optional in app runtime.
SUPABASE_ACCESS_TOKEN=

# ── Auth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Azure AD (Outlook/Teams) — optional
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
# Slack OAuth — optional (direct Slack integration)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

NEXTAUTH_URL=http://localhost:9000
NEXTAUTH_SECRET=your-random-secret
# 256-bit hex used to encrypt OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=your-256-bit-hex-key
# Internal API key for server-to-server calls
HEARST_API_KEY=your-api-key

# DANGER: HEARST_DEV_AUTH_BYPASS=1 disables all admin protections (admin routes,
# requireAdmin helper, permission checks). Use ONLY in local dev. The boot guard
# in lib/env.server.ts throws if =1 in NODE_ENV=production.
HEARST_DEV_AUTH_BYPASS=0

# ── LLM core ──
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI — used only for memory LTM embeddings (text-embedding-3-small, 1536d).
# Without this key, semantic cross-thread retrieval is disabled (fail-soft).
OPENAI_API_KEY=sk-...
# DeepSeek R1 (advanced reasoning) — optional fallback
DEEPSEEK_API_KEY=

# ── Connectors ──
# Composio (Tool Router + 1500+ pre-built agent actions) — REQUIRED for connectors
# 1. Get a key (ak_…) at https://app.composio.dev/settings
# 2. Enable toolkits in Apps → toolkit → Setup → "Use Composio Managed Auth"
COMPOSIO_API_KEY=

# ── Capability providers (Phase B) ──
# Search
EXA_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
# Image gen — fal.ai (flux/schnell): https://fal.ai/dashboard
FAL_KEY=
# Audio (TTS) — ElevenLabs: https://elevenlabs.io/api
ELEVENLABS_API_KEY=
# Document parsing — LlamaParse (PDF/DOCX → Markdown): https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=
# Code sandbox — E2B: https://e2b.dev/docs/api-key
E2B_API_KEY=
# Video — HeyGen avatar: https://app.heygen.com/settings
HEYGEN_API_KEY=
# Video — Runway text-to-video: https://app.runwayml.com/
RUNWAY_API_KEY=
# Browser automation — Browserbase: https://browserbase.com/
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Meeting bot — Recall.ai: https://www.recall.ai/dashboard
# Without it, /api/v2/meetings/* returns 503 and MeetingStage shows a CTA.
RECALL_API_KEY=
# Optional: HMAC-secures /api/v2/meetings/webhook (recommended in prod)
RECALL_WEBHOOK_SECRET=
# Optional: override Recall API region (default us-east-1)
RECALL_API_BASE=
# Audio STT live — Deepgram (used as fallback outside Recall flow)
DEEPGRAM_API_KEY=
# Emotion detection — Hume
HUME_API_KEY=
HUME_SECRET_KEY=
# Lead enrichment
APOLLO_API_KEY=
PDL_API_KEY=

# ── Storage (current: Cloudflare R2 — to be replaced by Supabase Storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Async jobs / Queue ──
# REDIS_URL: dev local = redis://localhost:6379. Prod Vercel = leave empty
# (BullMQ workers are gated off on Vercel; jobs migrate to Inngest, see below).
REDIS_URL=

# ── Premium services (to be configured) ──

# Inngest — durable serverless job orchestration (replaces BullMQ on Vercel)
# https://app.inngest.com/sign-up
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis — REST API for cache/WAL on serverless (replaces ioredis TCP)
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error tracking + traces + session replay
# https://sentry.io/signup/
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Axiom — structured logs + search (Vercel log drain native)
# https://app.axiom.co/register
AXIOM_TOKEN=
AXIOM_DATASET=hearst-vercel

# Resend — transactional email (magic links, notifications)
# https://resend.com/signup
RESEND_API_KEY=
RESEND_FROM_EMAIL=""

# Langfuse Cloud — LLM observability (prompts, outputs, eval)
# https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Arcjet — rate limiting + anti-bot + email validation
# https://app.arcjet.com/
ARCJET_KEY=

# ── Feature flags ──
# Mission Control B1 — agentic planner (preview + StepGraph + approval inline).
# Default: false in prod, true in dev (NODE_ENV=development).
# Flag is read per-request — no restart needed to toggle.
HEARST_ENABLE_PLANNER=false
