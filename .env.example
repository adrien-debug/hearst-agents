# ── HEARST OS — Environment Variables ──

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:9000
NEXTAUTH_SECRET=your-random-secret

# Token encryption (256-bit hex)
TOKEN_ENCRYPTION_KEY=your-256-bit-hex-key

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# API Auth
HEARST_API_KEY=your-api-key

# Microsoft / Outlook (Azure AD) — optional
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# Nango (200+ integrations) — REQUIRED for connectors
# Get your secret key from https://app.nango.dev/settings
NANGO_SECRET_KEY=your-nango-secret-key
NANGO_HOST=https://api.nango.dev

# Optional: Nango webhook verification
NANGO_WEBHOOK_SECRET=

# QA testing bypass (development only)
HEARST_DEV_AUTH_BYPASS=0
