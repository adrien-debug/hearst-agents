# ── HEARST OS — Environment Variables ──

# Local: ouverture auto des URLs dans Google Chrome (npm run dev, npm run launch). Mettre à 0 pour désactiver.
HEARST_OPEN_CHROME=1

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:9000
NEXTAUTH_SECRET=your-random-secret

# Token encryption (256-bit hex)
TOKEN_ENCRYPTION_KEY=your-256-bit-hex-key

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# API Auth
HEARST_API_KEY=your-api-key

# Microsoft / Outlook (Azure AD) — optional
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# Slack OAuth — optional (direct Slack integration)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Composio (Tool Router + 1500+ pre-built agent actions) — REQUIRED for connectors
# Setup:
#   1. Get a key (format `ak_…`) from https://app.composio.dev/settings
#   2. Enable the toolkits you want users to connect (Apps → toolkit → Setup
#      → "Use Composio Managed Auth")
# Without this key, /apps surfaces an explicit error and write-op handlers
# fall back to their stub responses.
COMPOSIO_API_KEY=

# Search providers (Phase 1.4 — web search premium)
EXA_API_KEY=
TAVILY_API_KEY=

# AI Providers — Phase 1.5
# fal.ai (génération d'images — flux/schnell) : https://fal.ai/dashboard
FAL_KEY=
# DeepSeek R1 (raisonnement avancé) : https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# LlamaParse (parsing PDF/DOCX → Markdown) : https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=
# E2B (exécution de code sandbox) : https://e2b.dev/docs/api-key
E2B_API_KEY=
# HeyGen (génération vidéo avatar) : https://app.heygen.com/settings
HEYGEN_API_KEY=
# Runway (génération vidéo text-to-video) : https://app.runwayml.com/
RUNWAY_API_KEY=

# QA testing bypass (development only)
HEARST_DEV_AUTH_BYPASS=0
