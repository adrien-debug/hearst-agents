{
  "name": "hearst-os",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti tcp:9000 | xargs kill -9 2>/dev/null || true; sleep 1; mkdir -p .next && xattr -w com.apple.fileprovider.ignore#P 1 .next 2>/dev/null; next dev -p 9000",
    "dev:solo": "npm run dev",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:fresh": "lsof -ti tcp:9000 | xargs kill -9 2>/dev/null || true; sleep 1; rm -rf .next && npm run dev",
    "launch": "./launch.sh",
    "launch:all": "./launch.sh",
    "stop": "./launch-stop.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:visual": "node scripts/lint-visual.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "composio:enable-all": "node --env-file=.env.local scripts/composio-bulk-enable.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/mcp": "^1.0.36",
    "@alloc/quick-lru": "^5.2.0",
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@composio/core": "^0.6.11",
    "@supabase/supabase-js": "^2.103.3",
    "ai": "^6.0.168",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
