{
  "name": "hearst-os",
  "version": "1.0.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "lsof -ti tcp:9001 | xargs kill -9 2>/dev/null || true; sleep 1; mkdir -p .next && xattr -w com.apple.fileprovider.ignore#P 1 .next 2>/dev/null; next dev -p 9001",
    "dev:solo": "npm run dev",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:fresh": "lsof -ti tcp:9001 | xargs kill -9 2>/dev/null || true; sleep 1; rm -rf .next && npm run dev",
    "electron:compile": "node scripts/build-electron.mjs",
    "electron": "npm run electron:compile && unset ELECTRON_RUN_AS_NODE && electron .",
    "dev:electron": "npm run electron:compile && unset ELECTRON_RUN_AS_NODE && concurrently -n next,electron -c cyan,yellow \"npm run dev\" \"wait-on http://localhost:9001 && electron .\"",
    "electron:build": "next build && npm run electron:compile",
    "electron:dist": "ELECTRON_RUN_AS_NODE= npm run electron:build && electron-builder",
    "launch": "./launch.sh",
    "launch:all": "./launch.sh",
    "stop": "./launch-stop.sh",
    "prebuild": "npm run lint:visual",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && node scripts/lint-visual.mjs",
    "lint:visual": "node scripts/lint-visual.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "composio:enable-all": "node --env-file=.env.local scripts/composio-bulk-enable.mjs",
    "health": "npx tsx scripts/health-check.ts",
    "workers:audit": "bash scripts/next-worker-helper.sh",
    "workers:kill-orphans": "bash scripts/next-worker-helper.sh --kill-orphans"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/mcp": "^1.0.36",
    "@alloc/quick-lru": "^5.2.0",
    "@anthropic-ai/sdk": "^0.90.0",
    "@arcjet/next": "^1.4.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@axiomhq/js": "^1.6.0",
    "@browserbasehq/sdk": "^2.10.0",
    "@composio/core": "^0.6.11",
    "@deepgram/sdk": "^5.1.0",
    "@e2b/code-interpreter": "^2.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.168",
    "bullmq": "^5.76.3",
    "cytoscape": "^3.33.2",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "inngest": "^4.2.6",
    "ioredis": "^5.10.1",
    "langfuse": "^3.38.20",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "three": "^0.184.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.0",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
